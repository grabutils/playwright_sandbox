{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run 4-Agent QA Mesh",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/run-agents.ps1"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true,
        "echo": true,
        "clear": true
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
