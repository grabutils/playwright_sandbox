{
  "_meta": {
    "app": "https://www.saucedemo.com",
    "story": "SCRUM-101",
    "priority": "1=getByRole/ARIA, 2=getByLabel/Placeholder, 3=getByTestId(data-test), 4=stable #id",
    "notes": "All data-test attributes confirmed via live DOM inspection."
  },

  "loginPage": {
    "usernameInput": {
      "placeholder": "Username",
      "testId": "username",
      "fallback": "#user-name",
      "selector": "[data-test='username']"
    },
    "passwordInput": {
      "placeholder": "Password",
      "testId": "password",
      "fallback": "#password",
      "selector": "[data-test='password']"
    },
    "loginButton": {
      "role": "button",
      "name": "Login",
      "testId": "login-button",
      "fallback": "#login-button",
      "selector": "[data-test='login-button']",
      "notes": "Rendered as INPUT[type=submit]."
    },
    "loginErrorMessage": {
      "testId": "error",
      "selector": "[data-test='error']"
    }
  },

  "header": {
    "hamburgerMenuButton": {
      "role": "button",
      "name": "Open Menu",
      "testId": "open-menu",
      "fallback": "#react-burger-menu-btn",
      "selector": "[data-test='open-menu']"
    },
    "appLogo": {
      "role": "heading",
      "name": "Swag Labs",
      "level": 1,
      "selector": "h1"
    },
    "cartLink": {
      "role": "link",
      "testId": "shopping-cart-link",
      "fallback": "#shopping_cart_container",
      "selector": "[data-test='shopping-cart-link']"
    },
    "cartBadge": {
      "testId": "shopping-cart-badge",
      "selector": "[data-test='shopping-cart-badge']",
      "notes": "Only present in DOM when cart has items."
    }
  },

  "inventoryPage": {
    "pageHeading": {
      "role": "heading",
      "name": "Products",
      "level": 2,
      "selector": "h2"
    },
    "productSortDropdown": {
      "role": "combobox",
      "testId": "product-sort-container",
      "selector": "[data-test='product-sort-container']"
    },
    "inventoryList": {
      "testId": "inventory-list",
      "selector": "[data-test='inventory-list']"
    },
    "inventoryItem": {
      "testId": "inventory-item",
      "selector": "[data-test='inventory-item']"
    },
    "itemDescription": {
      "testId": "inventory-item-desc",
      "selector": "[data-test='inventory-item-desc']"
    },
    "itemPrice": {
      "testId": "inventory-item-price",
      "selector": "[data-test='inventory-item-price']"
    },
    "addToCartBackpack": {
      "role": "button",
      "name": "Add to cart",
      "testId": "add-to-cart-sauce-labs-backpack",
      "selector": "[data-test='add-to-cart-sauce-labs-backpack']"
    },
    "removeBackpack": {
      "role": "button",
      "name": "Remove",
      "testId": "remove-sauce-labs-backpack",
      "selector": "[data-test='remove-sauce-labs-backpack']"
    },
    "addToCartBikeLight": {
      "role": "button",
      "name": "Add to cart",
      "testId": "add-to-cart-sauce-labs-bike-light",
      "selector": "[data-test='add-to-cart-sauce-labs-bike-light']"
    },
    "addToCartBoltTShirt": {
      "role": "button",
      "name": "Add to cart",
      "testId": "add-to-cart-sauce-labs-bolt-t-shirt",
      "selector": "[data-test='add-to-cart-sauce-labs-bolt-t-shirt']"
    },
    "addToCartFleeceJacket": {
      "role": "button",
      "name": "Add to cart",
      "testId": "add-to-cart-sauce-labs-fleece-jacket",
      "selector": "[data-test='add-to-cart-sauce-labs-fleece-jacket']"
    },
    "addToCartOnesie": {
      "role": "button",
      "name": "Add to cart",
      "testId": "add-to-cart-sauce-labs-onesie",
      "selector": "[data-test='add-to-cart-sauce-labs-onesie']"
    },
    "addToCartRedTShirt": {
      "role": "button",
      "name": "Add to cart",
      "testId": "add-to-cart-test.allthethings()-t-shirt-(red)",
      "selector": "[data-test='add-to-cart-test.allthethings()-t-shirt-(red)']"
    },
    "backpackTitleLink": {
      "role": "link",
      "name": "Sauce Labs Backpack",
      "testId": "item-4-title-link",
      "selector": "[data-test='item-4-title-link']"
    }
  },

  "cartPage": {
    "pageHeading": {
      "role": "heading",
      "name": "Your Cart",
      "level": 2,
      "selector": "h2"
    },
    "cartContentsContainer": {
      "testId": "cart-contents-container",
      "selector": "[data-test='cart-contents-container']"
    },
    "cartList": {
      "testId": "cart-list",
      "selector": "[data-test='cart-list']"
    },
    "cartItem": {
      "cssClass": ".cart_item",
      "selector": ".cart_item",
      "notes": "data-test='cart-item' is absent in current DOM; .cart_item class is reliable."
    },
    "itemQuantity": {
      "testId": "item-quantity",
      "selector": "[data-test='item-quantity']"
    },
    "cartItemDescription": {
      "testId": "inventory-item-desc",
      "selector": "[data-test='inventory-item-desc']"
    },
    "cartItemPrice": {
      "testId": "inventory-item-price",
      "selector": "[data-test='inventory-item-price']"
    },
    "removeBackpackFromCart": {
      "role": "button",
      "name": "Remove",
      "testId": "remove-sauce-labs-backpack",
      "selector": "[data-test='remove-sauce-labs-backpack']"
    },
    "continueShoppingButton": {
      "role": "button",
      "name": "Continue Shopping",
      "testId": "continue-shopping",
      "selector": "[data-test='continue-shopping']"
    },
    "checkoutButton": {
      "role": "button",
      "name": "Checkout",
      "testId": "checkout",
      "selector": "[data-test='checkout']",
      "notes": "FLAG-002: Enabled even when cart is empty."
    }
  },

  "checkoutInfoPage": {
    "pageHeading": {
      "role": "heading",
      "name": "Checkout: Your Information",
      "level": 2,
      "selector": "h2"
    },
    "checkoutInfoContainer": {
      "testId": "checkout-info-container",
      "selector": "[data-test='checkout-info-container']"
    },
    "firstNameInput": {
      "getByPlaceholder": "First Name",
      "testId": "firstName",
      "fallback": "#first-name",
      "selector": "[data-test='firstName']"
    },
    "lastNameInput": {
      "getByPlaceholder": "Last Name",
      "testId": "lastName",
      "fallback": "#last-name",
      "selector": "[data-test='lastName']"
    },
    "postalCodeInput": {
      "getByPlaceholder": "Zip/Postal Code",
      "testId": "postalCode",
      "fallback": "#postal-code",
      "selector": "[data-test='postalCode']"
    },
    "cancelButton": {
      "role": "button",
      "name": "Cancel",
      "testId": "cancel",
      "selector": "[data-test='cancel']",
      "notes": "Rendered as INPUT[type=button]. Navigates back to /cart.html."
    },
    "continueButton": {
      "role": "button",
      "name": "Continue",
      "testId": "continue",
      "selector": "[data-test='continue']"
    },
    "errorMessage": {
      "testId": "error",
      "selector": "[data-test='error']",
      "notes": "Known messages: 'Epic sadface :( First Name is required', 'Epic sadface :( Last Name is required', 'Epic sadface :( Postal Code is required'."
    },
    "errorCloseButton": {
      "ariaLabel": "Close",
      "selector": "[data-test='error'] button",
      "notes": "No data-test attribute. Has aria-label='Close'."
    }
  },

  "checkoutOverviewPage": {
    "pageHeading": {
      "role": "heading",
      "name": "Checkout: Overview",
      "level": 2,
      "selector": "h2"
    },
    "checkoutSummaryContainer": {
      "testId": "checkout-summary-container",
      "selector": "[data-test='checkout-summary-container']"
    },
    "overviewCartList": {
      "testId": "cart-list",
      "selector": "[data-test='cart-list']"
    },
    "overviewCartItem": {
      "testId": "cart-item",
      "selector": "[data-test='cart-item']"
    },
    "overviewItemQuantity": {
      "testId": "item-quantity",
      "selector": "[data-test='item-quantity']"
    },
    "overviewItemDescription": {
      "testId": "inventory-item-desc",
      "selector": "[data-test='inventory-item-desc']"
    },
    "overviewItemPrice": {
      "testId": "inventory-item-price",
      "selector": "[data-test='inventory-item-price']"
    },
    "paymentInfoLabel": {
      "testId": "payment-info-label",
      "selector": "[data-test='payment-info-label']"
    },
    "paymentInfoValue": {
      "testId": "payment-info-value",
      "selector": "[data-test='payment-info-value']",
      "notes": "Value: 'SauceCard #31337'"
    },
    "shippingInfoLabel": {
      "testId": "shipping-info-label",
      "selector": "[data-test='shipping-info-label']"
    },
    "shippingInfoValue": {
      "testId": "shipping-info-value",
      "selector": "[data-test='shipping-info-value']",
      "notes": "Value: 'Free Pony Express Delivery!'"
    },
    "subtotalLabel": {
      "testId": "subtotal-label",
      "selector": "[data-test='subtotal-label']",
      "notes": "Format: 'Item total: $XX.XX'"
    },
    "taxLabel": {
      "testId": "tax-label",
      "selector": "[data-test='tax-label']",
      "notes": "Format: 'Tax: $X.XX'"
    },
    "totalLabel": {
      "testId": "total-label",
      "selector": "[data-test='total-label']",
      "notes": "Format: 'Total: $XX.XX'"
    },
    "cancelButton": {
      "role": "button",
      "name": "Cancel",
      "testId": "cancel",
      "selector": "[data-test='cancel']",
      "notes": "Navigates to /inventory.html (not /cart.html — see FLAG-003)."
    },
    "finishButton": {
      "role": "button",
      "name": "Finish",
      "testId": "finish",
      "selector": "[data-test='finish']"
    }
  },

  "checkoutCompletePage": {
    "pageHeading": {
      "role": "heading",
      "name": "Checkout: Complete!",
      "level": 2,
      "selector": "h2"
    },
    "checkoutCompleteContainer": {
      "testId": "checkout-complete-container",
      "selector": "[data-test='checkout-complete-container']"
    },
    "thankYouHeading": {
      "role": "heading",
      "name": "Thank you for your order!",
      "selector": "getByRole('heading', { name: 'Thank you for your order!' })",
      "notes": "Not in h3; use getByRole with name for cross-version resilience."
    },
    "backHomeButton": {
      "role": "button",
      "name": "Back Home",
      "testId": "back-to-products",
      "selector": "[data-test='back-to-products']"
    }
  },

  "urls": {
    "login": "https://www.saucedemo.com/",
    "inventory": "https://www.saucedemo.com/inventory.html",
    "cart": "https://www.saucedemo.com/cart.html",
    "checkoutStepOne": "https://www.saucedemo.com/checkout-step-one.html",
    "checkoutStepTwo": "https://www.saucedemo.com/checkout-step-two.html",
    "checkoutComplete": "https://www.saucedemo.com/checkout-complete.html"
  },

  "knownPrices": {
    "sauceLabsBackpack": "$29.99",
    "sauceLabsBikeLight": "$9.99",
    "sauceLabsBoltTShirt": "$15.99",
    "sauceLabsFleeceJacket": "$49.99",
    "sauceLabsOnesie": "$7.99",
    "redTShirt": "$15.99",
    "backpackTaxSingleItem": "$2.40",
    "backpackTotalSingleItem": "$32.39"
  }
}
